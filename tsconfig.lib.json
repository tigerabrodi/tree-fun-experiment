{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.lib.tsbuildinfo",
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist-lib",
    "rootDir": "./src"
  },
  "include": [
    "src/lib/**/*.ts",
    "src/engine/**/*.ts",
    "src/three/**/*.ts",
    "src/declarations.d.ts",
    "src/window-debug.d.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/app.tsx",
    "src/main.tsx",
    "src/components/**/*"
  ]
}
